  {
    "endpoint": "/api/products",
    "method": "POST",
    "description": "Creates a new produce product listing. Existing endpoint remains unchanged by the landing page request.",
    "authentication": true,
    "request": {
      "headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer <token>"
      },
      "params": {},
      "query": {},
      "body": {
        "name": {
          "type": "string",
          "required": true,
          "example": "Organic Mangoes"
        },
        "category": {
          "type": "string",
          "required": true,
          "example": "Fruit"
        },
        "price": {
          "type": "number",
          "required": true,
          "example": 3.99
        },
        "unit": {
          "type": "string",
          "required": true,
          "example": "lb"
        },
        "stock": {
          "type": "number",
          "required": false,
          "example": 25
        },
        "status": {
          "type": "string",
          "required": false,
          "example": "active"
        },
        "accent": {
          "type": "string",
          "required": false,
          "example": "#f97316"
        }
      }
    },
    "response": {
      "success": {
        "status": 200,
        "body": {
          "success": true,
          "data": {
            "id": "generated-product-id",
            "name": "Organic Mangoes",
            "category": "Fruit",
            "price": 3.99,
            "unit": "lb",
            "stock": 25,
            "status": "active",
            "accent": "#f97316"
          }
        }
      },
      "errors": [
        {
          "status": 400,
          "code": "VALIDATION_ERROR",
          "message": "Name, category, price, and unit are required"
        }
      ]
    }
  },
