    "request": {
      "headers": {
        "Content-Type": "application/json"
      },
      "params": {},
      "query": {},
      "body": {
        "email": {
          "type": "string",
          "required": true,
          "example": "demo@example.com"
        },
        "password": {
          "type": "string",
          "required": true,
          "example": "demo123"
        }
      }
    },
    "response": {
      "success": {
        "status": 200,
        "body": {
          "success": true,
          "data": {
            "token": "jwt-token",
